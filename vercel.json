{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/dashboard/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/lineage/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/dashboard/" }
  ]
}
