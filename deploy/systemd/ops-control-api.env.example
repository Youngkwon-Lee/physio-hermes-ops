# copy to ~/.config/physio-hermes-ops/ops-control-api.env
# backward-compatible single token
# OPS_CTL_TOKEN=replace_with_long_random_token

# split token (read vs execute)
OPS_CTL_READ_TOKEN=replace_with_long_random_read_token

# execute token modes
# 1) single execute token
# OPS_CTL_EXEC_TOKEN=replace_with_long_random_exec_token

# 2) role-based execute tokens (recommended)
OPS_CTL_EXEC_ADMIN_TOKEN=replace_with_long_random_exec_admin_token
OPS_CTL_EXEC_OPERATOR_TOKEN=replace_with_long_random_exec_operator_token

# durable Mission Control state shared across canonical repo and temporary worktrees
# defaults to ~/.local/state/physio-hermes-ops/mission_control
# OPS_CTL_STATE_DIR=/home/yk/.local/state/physio-hermes-ops/mission_control
# OPS_CTL_HANDOFF_INBOX_PATH=/home/yk/.local/state/physio-hermes-ops/mission_control/handoff_inbox.json

# optional: required only for Discord thread -> Mission Control ingest polling
# HERMES_DISCORD_BOT_TOKEN=replace_with_discord_bot_token

# optional: mirror Discord Mission Control tasks into Kinelo Ops operations inbox
# KINELO_OPS_INTAKE_URL=https://kinelo-ops.vercel.app/api/ops-intake
# KINELO_OPS_INTAKE_SECRET=replace_with_kinelo_ops_intake_secret
# DISCORD_GUILD_ID=replace_with_discord_server_id_for_source_urls
